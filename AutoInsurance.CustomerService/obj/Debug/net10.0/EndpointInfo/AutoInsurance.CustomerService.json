  "components": {
    "schemas": {
      "CustomerCreateDto": {
        "required": [
          "address",
          "city",
          "dateOfBirth",
          "email",
          "fullName",
          "licenseNumber",
          "phone",
          "state",
          "zipCode"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 2,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phone": {
            "minLength": 1,
            "pattern": "^\\d{10}$",
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "licenseNumber": {
            "maxLength": 20,
            "minLength": 5,
            "type": "string"
          },
          "address": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "city": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "state": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "zipCode": {
            "minLength": 1,
            "pattern": "^\\d{6}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CustomerUpdateDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
